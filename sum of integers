import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter number of integers: ");
        int n = sc.nextInt();
        int sum = 0;
        System.out.println("Enter integers:");
        for (int i = 0; i < n; i++) {
            int num = sc.nextInt();
            sum = sum + num;
        }
        System.out.println("Sum = " + sum);
        sc.close();
    }
}
